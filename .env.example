# WangLinS Grok signup config — copy to .env and fill in your own values

# 9router
ROUTER9_URL=https://your-9router.example
ROUTER9_PASS=your_9router_password

# Temp mail provider (@wanglinsaputra/tempmail-wrapper)
# mail.tm | guerrillamail | yopmail | dropmail | 1secemail | ncaori | zoromail |
# tempmail.lol | tempmailc | temp-mail.io | tempmail.plus | emailfake |
# generator.email | mailnesia | 10minutemail | email-temp
# Multi provider: comma/pipe list. Round-robin per account; fallback if create fails.
# x.ai blocks many disposable domains (mailto.plus, yopmail, …).
# Proven OK: ncaori (ncaori.my.id / nca.my.id)
# TEMPMAIL_PROVIDER=ncaori
TEMPMAIL_PROVIDER=ncaori,zoromail

# Password for the Grok accounts being created (min 16 chars)
PASSWORD=YourStrongPassword123

# Optional: path ke Google Chrome real (auto-detect kalau kosong)
# CHROME_PATH=/usr/bin/google-chrome-stable
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# false = real window (recommended, CF deteksi headless)
# true  = headless (sering kena CF)
HEADLESS=false

# --- Turnstile sealed extension (remote unlock) — WAJIB untuk create akun ---
SEAL_UNLOCK_URL=https://wanglins.6n6.web.id
SEAL_TOKEN=e4k-0Dil5dKU82VlBLzp50AdWmWVPCdc
